#!/bin/sh

function check_dependency() {
    echo "${install_dependencies}" | grep -qie "\b${1}\b"
}

if ! check_dependency "R"; then
    export r_packages=
fi

if ! check_dependency "python"; then
    export python_packages=
fi

if ! check_dependency "ubuntu"; then
    export ubuntu_packages=
fi

export GITLAB_REGISTRY_PATH="${CI_REGISTRY_IMAGE}/${CI_COMMIT_BRANCH}/${IMAGE_NAME}";

command="$(
cat << EOF
/kaniko/executor
    --context "./"
    --dockerfile "./Dockerfile"
    --build-arg "ubuntu_packages"="\${ubuntu_packages}"
    --build-arg "r_packages"="\${r_packages}"
    --build-arg "python_packages"="\${python_packages}"
    --build-arg "workdir"="/\${CI_PROJECT_TITLE}/"
    --build-arg "outdir"="/\${CI_PROJECT_TITLE}_output/"
    --build-arg "FROM_IMAGE"="\${FROM_IMAGE}"
    --destination "\${GITLAB_REGISTRY_PATH}:\${IMAGE_VERS}"
    --destination "\${GITLAB_REGISTRY_PATH}:latest"
EOF
)"
CI_COMMIT_BRANCH="main"

if [[ "${CI_COMMIT_BRANCH}" == "main" ]]; then
    export GITLAB_REGISTRY_MAIN_PATH="${CI_REGISTRY_IMAGE}/${IMAGE_NAME}";
    export DOCKERHUB_REGISTRY_PATH="index.docker.io/simonlenau/dev-container:${IMAGE_NAME}"; 
    command="$(
cat << EOF
${command}
    --destination "\${GITLAB_REGISTRY_MAIN_PATH}:\${image_vers}"
    --destination "\${GITLAB_REGISTRY_MAIN_PATH}:latest"
    --destination "\${DOCKERHUB_REGISTRY_PATH}_\${image_vers}"
    --destination "\${DOCKERHUB_REGISTRY_PATH}_latest"
EOF
)"
fi


printf "%s\n" "$command"

${command}