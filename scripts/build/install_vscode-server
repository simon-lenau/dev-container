#!/bin/bash

echo "vscode-server pre-install-script currently does not seem to work"

exit 0

current_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

chmod u+rwx "${current_dir}/download-vs-code-server" &&
    printf -- "Installing vscode-server..." &&
    ${current_dir}/download-vs-code-server ${@} >"${current_dir}/vscode-server.log" 2>&1 &&
    (
        printf -- "successful!\n" &&
            rm -rf "${current_dir}/vscode-server.log"
    ) ||
    (
        sed -i 's/^/\t/' "${current_dir}/vscode-server.log" &&
            printf -- "failed:\n" &&
            cat "${current_dir}/vscode-server.log" &&
            exit 1
    )
