#!/bin/bash

$(
    cd "$(dirname "${BASH_SOURCE[0]}")" &&
        chmod u+rwx ./download-vs-code-server &&
        printf -- "Installing vscode-server..." &&
        ./download-vs-code-server >vscode-server.log 2>&1 &&
        (
            echo "... successful!" &&
                rm -rf vscode-server.log
        ) ||
        (
            sed -i 's/^/\t/' vscode-server.log && printf -- "failed:\n" &&
                cat vscode-server.log &&
                exit 1
        )
)
