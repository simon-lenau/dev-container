if [ -n "${__vscode-server_init_run__}" ]; then return 0; fi
export __vscode_server_init_run__=true

function make_link {
    if [ -d "/root/${1}" ]; then
        if [ ! -d "${HOME}/${1}" ]; then
            ln -s "/root/${1}" "$HOME/${1}"
        fi
    fi
}

make_link ".vscode-server"
make_link ".vscode"
make_link "code-server"
make_link "code"
