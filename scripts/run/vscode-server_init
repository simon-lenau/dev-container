if [ -n "${__vscode-server_init_run__}" ]; then return 0; fi
export __vscode_server_init_run__=true

function link_if_exists {
    if [ -d "/root/.vscode-server" ]; then
        ln -s /root/.vscode-server $HOME
    fi
}

link_if_exists "/root/.vscode-server"
link_if_exists "/root/.vscode"
link_if_exists "/root/code-server"
link_if_exists "/root/code"
