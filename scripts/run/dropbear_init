mkdir -p $HOME/.ssh

chmod go-rwx ~/.ssh/authorized_keys

cd /etc/dropbear

# Delete existing host keys
rm -rf ./dropbear_*_host_key

# To generate host keys, use this:
# dropbearkey -t ed25519 -f /etc/dropbear/dropbear_ed25519_host_key
# dropbearkey -t ecdsa -f /etc/dropbear/dropbear_ecdsa_host_key
# dropbearkey -t rsa -f /etc/dropbear/dropbear_rsa_host_key

# To use predefined host keys, use this:
# … openssl base64 < /etc/dropbear/dropbear_rsa_host_key > /etc/dropbear/dropbear_rsa_host_key.txt
cat /etc/dropbear/dropbear_rsa_host_key.txt | openssl base64 -d > /etc/dropbear/dropbear_rsa_host_key
# … openssl base64 < /etc/dropbear/dropbear_ed25519_host_key > /etc/dropbear/dropbear_ed25519_host_key.txt
cat /etc/dropbear/dropbear_ed25519_host_key.txt | openssl base64 -d > /etc/dropbear/dropbear_ed25519_host_key
# … openssl base64 < /etc/dropbear/dropbear_ecdsa_host_key > /etc/dropbear/dropbear_ecdsa_host_key.txt
cat /etc/dropbear/dropbear_ecdsa_host_key.txt | openssl base64 -d > /etc/dropbear/dropbear_ecdsa_host_key

dropbear -F -E -p $(id -u)
