#!/usr/bin/env bash

source "${DEV_CONTAINER_DIR}/dropbear_settings"

# Delete existing host keys
cd ${DROPBEAR_FOLDER}
rm -rf ./host_key_*


source "${DEV_CONTAINER_DIR}/ssh_key_setup" "insert"

port=$(id -u)

if [ ! "${port}" -gt 0 ]; then
    port=11782
fi

# Add script to .bashrc that automatically changes the directory of vscode to $WORKDIR with a time limit
bashrc_path="$HOME/.bashrc"

begin_delim="# >>>>>>>>>>>>>>>>>>>> dev-container shell setup >>>>>>>>>>>>>>>>>>>> "
end_delim="# <<<<<<<<<<<<<<<<<<<< dev-container shell setup <<<<<<<<<<<<<<<<<<<< "

if ! grep -iq "${begin_delim}" "${bashrc_path}"; then
    cat >>${bashrc_path} <<EOF
${begin_delim}
export DEV_CONTAINER_DIR=${DEV_CONTAINER_DIR}
source \$DEV_CONTAINER_DIR/run/ssh_shell_setup
${end_delim}
EOF
fi

# Check if keys have been changed in comparison to those
# publicly available on git
${DEV_CONTAINER_DIR}/run/dropbear_check_keys || {
    # Store cursor position
    tput_store_cursor
    printf "\n%s\n" "Do you wish to proceed? (yes / no)"
    read -n 255 -t 30 answer
    # Restore cursor position and clear everything afterwards
    tput_restore_and_clear

    if (echo "${answer}" | grep "[Yy]\([Ee][Ss]\)\{1,1\}"); then
        echo "OK"
    else
        exit 1
    fi
}

echo "----------------------------------------------------"
printf "Running on %s, port %s\n" "$HOST$HOSTNAME" "$port"
echo "----------------------------------------------------"

dropbear -F -E -s -p $port
